rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function hasCompanyEmail() {
      return request.auth.token.email is string
        && request.auth.token.email.matches('.*@jdtnurseries\\.com$');
    }
    function isCompanyUser() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && hasCompanyEmail();
    }
    function allowedPersonnelRoles() {
      return [
        "Admin",
        "Owner",
        "Crew Leader",
        "Crew Member",
        "Sales",
        "Irrigation Tech",
        "Driver",
        "Mechanic",
        "Project Manager",
        "Operations Coordinator",
        "Contractor"
      ];
    }
    function fullAccessRoles() { return ["Admin", "Owner"]; }
    function hasFullAccessRole() {
      return request.auth.token.role in fullAccessRoles();
    }
    function hasOwnerEmail() {
      return request.auth.token.email in [
        "Office@jdtnurseries.com",
        "office@jdtnurseries.com",
        "jeremy@jdtnurseries.com"
      ];
    }
    function isFullAccess() {
      return isCompanyUser() && (hasOwnerEmail() || hasFullAccessRole());
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isKnownPersonnelRole(role) { return role in allowedPersonnelRoles(); }
    function isAllowedAuthorizationLevel(level) {
      return level in ["full", "manager", "field", "external"];
    }
    function isFullAccessAssignment(data) {
      return (('role' in data) && data.role in fullAccessRoles())
        || (('authorizationLevel' in data) && data.authorizationLevel == "full");
    }
    function isCrewWriteValid(data) {
      return (!('role' in data) || (
          data.role is string
          && (isKnownPersonnelRole(data.role) || data.role.size() <= 64)
        ))
        && (!('authorizationLevel' in data) || isAllowedAuthorizationLevel(data.authorizationLevel))
        && (!isFullAccessAssignment(data) || isFullAccess());
    }
    
    // Company-wide access (all verified users can read, but must be signed in)
    // For this internal tool, we assume verified users are employees.

    // Entities Validation
    function isCommonValid(data) {
      return ('id' in data || true) // Relaxing since id is optional
        && ('createdAt' in data || true);
    }

    match /jobs/{jobId} {
      allow read: if isCompanyUser();
      allow create: if isCompanyUser() && isValidId(jobId);
      allow update: if isCompanyUser() && isValidId(jobId);
      allow delete: if isFullAccess() && isValidId(jobId);
    }

    match /loads/{loadId} {
      allow read: if isCompanyUser();
      allow create: if isCompanyUser() && isValidId(loadId);
      allow update: if isCompanyUser() && isValidId(loadId);
      allow delete: if isFullAccess() && isValidId(loadId);
    }

    match /ranchOaks/{treeId} {
      allow read: if isCompanyUser();
      allow create: if isCompanyUser() && isValidId(treeId);
      allow update: if isCompanyUser() && isValidId(treeId);
      allow delete: if isFullAccess() && isValidId(treeId);
    }

    match /equipment/{itemId} {
      allow read: if isCompanyUser();
      allow create: if isCompanyUser() && isValidId(itemId);
      allow update: if isCompanyUser() && isValidId(itemId);
      allow delete: if isFullAccess() && isValidId(itemId);
    }

    match /crews/{crewId} {
      allow read: if isCompanyUser();
      allow create: if isCompanyUser() && isValidId(crewId) && isCrewWriteValid(incoming());
      allow update: if isCompanyUser() && isValidId(crewId) && isCrewWriteValid(incoming());
      allow delete: if isFullAccess() && isValidId(crewId);
    }

    match /clients/{clientId} {
      allow read: if isCompanyUser();
      allow create: if isCompanyUser() && isValidId(clientId);
      allow update: if isCompanyUser() && isValidId(clientId);
      allow delete: if isFullAccess() && isValidId(clientId);
    }

    match /alerts/{alertId} {
      allow read: if isCompanyUser();
      allow create: if isCompanyUser() && isValidId(alertId);
      allow update: if isCompanyUser() && isValidId(alertId);
      allow delete: if isFullAccess() && isValidId(alertId);
    }
  }
}
